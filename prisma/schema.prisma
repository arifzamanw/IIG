generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  roleId    Int
  role      Role     @relation(fields: [roleId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sessions  Session[]
}

model Role {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  users       User[]
  permissions Permission[] @relation("RolePermissions")
}

model Permission {
  id    Int    @id @default(autoincrement())
  name  String @unique
  roles Role[] @relation("RolePermissions")
}

model Session {
  id        String   @id @default(uuid())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Developer {
  id          Int       @id @default(autoincrement())
  name        String
  logoUrl     String?
  description String?   @db.Text
  website     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  projects    Project[]
}

enum ProjectStatus {
  PLANNING
  UNDER_CONSTRUCTION
  COMPLETED
  CANCELLED
}

model Project {
  id             Int           @id @default(autoincrement())
  name           String
  description    String?       @db.Text
  address        String
  city           String
  status         ProjectStatus @default(PLANNING)
  completionDate DateTime?
  coverImageUrl  String?
  developerId    Int
  developer      Developer     @relation(fields: [developerId], references: [id], onDelete: Cascade)
  units          Unit[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([developerId])
}

enum UnitType {
  APARTMENT
  VILLA
  TOWNHOUSE
  PENTHOUSE
  PLOT
  COMMERCIAL
}

enum UnitStatus {
  AVAILABLE
  RESERVED
  SOLD
}

model Unit {
  id             Int        @id @default(autoincrement())
  unitNumber     String
  projectId      Int
  project        Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type           UnitType
  bedrooms       Int
  bathrooms      Int
  size           Float
  price          Decimal    @db.Decimal(15, 2)
  currency       String     @default("USD")
  status         UnitStatus @default(AVAILABLE)
  floorPlanUrl   String?
  view           String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([projectId])
}
