generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "mysql"
}

model User {
  id            Int            @id @default(autoincrement())
  email         String         @unique
  password      String
  name          String
  phone         String?
  isActive      Boolean        @default(true)
  roleId        Int
  role          Role           @relation(fields: [roleId], references: [id])
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  sessions      Session[]
  proposals     Proposal[]
  activityLogs  ActivityLog[]
}

model Role {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  users       User[]
  permissions Permission[] @relation("RolePermissions")
}

model Permission {
  id    Int    @id @default(autoincrement())
  name  String @unique
  roles Role[] @relation("RolePermissions")
}

model Session {
  id        String   @id @default(uuid())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Developer {
  id          Int       @id @default(autoincrement())
  name        String
  logoUrl     String?
  description String?   @db.Text
  website     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  projects    Project[]
}

enum ProjectStatus {
  PLANNING
  UNDER_CONSTRUCTION
  COMPLETED
  CANCELLED
}

model Project {
  id             Int               @id @default(autoincrement())
  name           String
  description    String?           @db.Text
  address        String
  city           String
  country        String            @default("Georgia")
  latitude       Float?
  longitude      Float?
  status         ProjectStatus     @default(PLANNING)
  isPublished    Boolean           @default(false)
  completionDate DateTime?
  startingPrice  Decimal?          @db.Decimal(15, 2)
  roi            Float?            // Return on Investment %
  coverImageUrl  String?
  developerId    Int
  developer      Developer         @relation(fields: [developerId], references: [id], onDelete: Cascade)
  units          Unit[]
  amenities      ProjectAmenity[]
  paymentPlans   PaymentPlan[]
  media          Media[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([developerId])
}

enum UnitType {
  APARTMENT
  VILLA
  TOWNHOUSE
  PENTHOUSE
  PLOT
  COMMERCIAL
}

enum UnitStatus {
  AVAILABLE
  RESERVED
  SOLD
}

model Unit {
  id             Int        @id @default(autoincrement())
  unitNumber     String
  projectId      Int
  project        Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type           UnitType
  bedrooms       Int
  bathrooms      Int
  size           Float
  price          Decimal    @db.Decimal(15, 2)
  currency       String     @default("USD")
  status         UnitStatus @default(AVAILABLE)
  floorPlanUrl   String?
  view           String?
  floor          Int?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([projectId])
}

enum AmenityCategory {
  RECREATION
  WELLNESS
  SECURITY
  CONNECTIVITY
  TRANSPORT
  RETAIL
  OTHER
}

model Amenity {
  id        Int               @id @default(autoincrement())
  name      String            @unique
  icon      String?           // Lucide icon name or emoji
  category  AmenityCategory   @default(OTHER)
  projects  ProjectAmenity[]
}

model ProjectAmenity {
  projectId  Int
  amenityId  Int
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  amenity    Amenity  @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@id([projectId, amenityId])
}

model PaymentPlan {
  id          Int      @id @default(autoincrement())
  name        String   // e.g. "40/60", "5% monthly"
  description String?  @db.Text
  projectId   Int
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  schedule    Json     // Array of { label, percentage, dueDays }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId])
}

enum MediaType {
  IMAGE
  FLOOR_PLAN
  BROCHURE
  VIDEO
  MASTER_PLAN
  DOCUMENT
}

model Media {
  id          Int       @id @default(autoincrement())
  projectId   Int
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type        MediaType
  url         String
  name        String?
  size        Int?      // file size in bytes
  mimeType    String?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())

  @@index([projectId])
}

// ─── CUSTOMERS ───────────────────────────────────────────

model Customer {
  id          Int        @id @default(autoincrement())
  name        String
  email       String?
  phone       String?
  nationality String?
  source      String?    // e.g. "Instagram", "Referral", "Walk-in"
  notes       String?    @db.Text
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  proposals   Proposal[]
}

// ─── PROPOSALS ───────────────────────────────────────────

enum ProposalStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
}

model Proposal {
  id              Int            @id @default(autoincrement())
  customerId      Int
  customer        Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  unitId          Int
  createdById     Int
  createdBy       User           @relation(fields: [createdById], references: [id])
  status          ProposalStatus @default(DRAFT)
  
  // Snapshot of project/unit data at proposal creation time (immutable)
  snapshot        Json
  
  // Sales customizations
  customPrice     Decimal?       @db.Decimal(15, 2)
  discountPercent Float?
  notes           String?        @db.Text
  customerMessage String?        @db.Text
  selectedImages  Json?          // Array of Media URLs chosen by salesperson
  selectedFloors  Json?          // Array of floor plan URLs
  
  pdfUrl          String?        // Path to generated PDF
  pdfGeneratedAt  DateTime?
  
  templateId      Int?
  template        ProposalTemplate? @relation(fields: [templateId], references: [id])
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([customerId])
  @@index([createdById])
  @@index([unitId])
}

// ─── ACTIVITY LOGS ────────────────────────────────────────

model ActivityLog {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id])
  action     String   // e.g. "CREATE", "UPDATE", "DELETE"
  entity     String   // e.g. "Project", "Unit", "Proposal"
  entityId   Int?
  details    Json?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
}

// ─── PROPOSAL TEMPLATES ───────────────────────────────────

model ProposalTemplate {
  id          Int        @id @default(autoincrement())
  name        String
  content     String     @db.LongText
  isDefault   Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  proposals   Proposal[]
}
